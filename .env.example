# Copy to .env. start-all.ps1 creates .env and randomizes secrets if it is missing.

# Secrets. Do not publish real .env.
WEBUI_SECRET_KEY=change-me-generate
MCPO_API_KEY=change-me-generate
IMAGE_RAG_API_KEY=change-me-generate

# Optional first-run Open WebUI admin bootstrap.
# If both email and password are set on a fresh data directory, Open WebUI creates
# the admin account automatically and disables signup. Never commit real values.
WEBUI_ADMIN_EMAIL=
WEBUI_ADMIN_PASSWORD=
WEBUI_ADMIN_NAME=Admin

# Multi-user policy. Default is first-run friendly.
# For a LAN production server, prefer WEBUI_ADMIN_EMAIL/WEBUI_ADMIN_PASSWORD
# before first start, then set ENABLE_SIGNUP=false after admin exists.
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=pending

# Native LM Studio on Windows.
# Local Docker Desktop usually works with host.docker.internal.
# WSL2 Docker Engine on Windows Server may need http://<windows-host-ip>:1234/v1 instead.
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_HEALTH_URL=http://127.0.0.1:1234/v1/models
LMSTUDIO_API_KEY=lm-studio

# For pure WSL Docker Engine, start-all.sh can auto-set this to the Windows gateway IP.
# Docker Desktop normally works with host-gateway.
HOST_DOCKER_INTERNAL_GATEWAY=host-gateway
WINDOWS_HOST_IP=

# Optional: set this to the exact/partial LM Studio model id you expect to be loaded.
# Example for local light testing: EXPECTED_LMSTUDIO_MODEL=gemma
# Example for server: EXPECTED_LMSTUDIO_MODEL=glm
EXPECTED_LMSTUDIO_MODEL=

# Published ports. Keep internal services on localhost unless you intentionally expose them.
WEBUI_BIND=0.0.0.0
WEBUI_PORT=3000
INTERNAL_BIND=127.0.0.1
INFINITY_PORT=7997
MCPO_PORT=8001
MINERU_PORT=8000

# Images and RAG models.
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
INFINITY_IMAGE=michaelf34/infinity:latest
INFINITY_EMBED_MODEL=BAAI/bge-m3
INFINITY_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Extra Infinity CLIP/image-text model. This is exposed for direct API use and checks.
INFINITY_IMAGE_EMBED_MODEL=jinaai/jina-clip-v1
INFINITY_API_KEY=infinity
RAG_EMBEDDING_BATCH_SIZE=1
RAG_EMBEDDING_CONCURRENT_REQUESTS=1
# Open WebUI retrieval/rerank wiring.
# Open WebUI hybrid retrieval. Rerank is used through this path.
ENABLE_RAG_HYBRID_SEARCH=true
ENABLE_RAG_HYBRID_SEARCH_ENRICHED_TEXTS=false
RAG_RERANKING_BATCH_SIZE=32
RAG_TOP_K_RERANKER=3
RAG_EXTERNAL_RERANKER_TIMEOUT=30

# GPU visibility inside Linux containers. On 2xH100 server, keep all until you deliberately split load.
INFINITY_GPU_DEVICES=all
MINERU_GPU_DEVICES=all
IMAGE_RAG_GPU_DEVICES=all

# Checks. GPU test may pull the CUDA smoke-test image on first run.
DOCKER_GPU_SMOKE_TEST=true
FUNCTIONAL_SMOKE_TEST=true

# First Infinity start downloads/loads models and can take several minutes.
OPENWEBUI_HEALTH_TRIES=60
INFINITY_HEALTH_TRIES=180
MCPO_HEALTH_TRIES=60
MINERU_HEALTH_TRIES=60
# Open WebUI document parsing through local MinerU API.
MINERU_API_TIMEOUT=300
MINERU_FILE_EXTENSIONS=pdf
MINERU_PARAMS={"backend":"pipeline","lang_list":["east_slavic"],"parse_method":"auto","formula_enable":true,"table_enable":true,"return_md":true}

# Visual/image RAG tool server. This is a separate OpenAPI tool in Open WebUI.
IMAGE_RAG_PORT=8010
IMAGE_RAG_CLIP_MODEL=clip-ViT-B-32
IMAGE_RAG_DEVICE=auto
IMAGE_RAG_RENDER_DPI=144
IMAGE_RAG_MAX_PAGES_PER_PDF=80
IMAGE_RAG_ROOTS=/data/papers,/data/openwebui
