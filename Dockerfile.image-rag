FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
      libgl1 libglib2.0-0 libgomp1 fonts-noto-core fonts-noto-cjk fontconfig && \
    fc-cache -fv && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN python -m pip install --no-cache-dir \
      fastapi==0.115.6 \
      uvicorn[standard]==0.34.0 \
      pydantic==2.10.4 \
      pymupdf==1.25.1 \
      pillow==11.1.0 \
      numpy==2.2.1 \
      sentence-transformers==3.3.1

COPY image_rag_service.py /app/image_rag_service.py

EXPOSE 8010
CMD ["uvicorn", "image_rag_service:app", "--host", "0.0.0.0", "--port", "8010"]
